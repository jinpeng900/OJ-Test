# ============================================================
# OJ AI 助手配置文件模板
# 使用方法：cp ai/.env.example ai/.env
#           然后将 your_api_key_here 替换为真实的 API Key
# ============================================================

# DeepSeek API Key（必填，否则 AI 助手功能不可用）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_api_key_here

# 可选：自定义 API 基础 URL（使用代理或私有部署时修改）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
